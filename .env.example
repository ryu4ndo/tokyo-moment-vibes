# Express API サーバー
PORT=3001
APP_URL=http://localhost:5173

# OpenAI API（サーバー側 — Express /api/chat 等）
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4.1-mini

# OpenAI API（クライアント AI サービス層 — src/services/ai.ts）
# 注意: VITE_ プレフィックスはビルドに含まれます。本番はサーバー経由を推奨。
VITE_OPENAI_API_KEY=sk-your-openai-api-key-here
VITE_OPENAI_MODEL=gpt-4.1-mini

# Google Maps（フロントエンド用・任意）
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# データソース: mock（ローカル）| api（Express API経由）
VITE_DATA_SOURCE=mock
VITE_API_BASE_URL=http://localhost:3001

# Google Places API（サーバー側・任意。未設定時はローカルデータにフォールバック）
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

# ── Supabase（バックエンド基盤）────────────────────────────────
# Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# サーバー側のみ（JWT検証・管理操作用・任意）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OAuth Redirect URLs（Supabase Auth → URL Configuration）:
#   http://localhost:5173
#   https://your-production-domain.com

# SQLマイグレーション: supabase/migrations/001_initial_schema.sql
# Supabase SQL Editor または `supabase db push` で適用

# ── PostgreSQL（任意 — 未設定時はインメモリ）────────────────────
# docker compose up -d postgres && npm run db:migrate
DATABASE_URL=postgresql://tokyo:tokyo@localhost:5432/tokyo_moment
DATABASE_SSL=false

# ── Stripe（任意 — 未設定時はデモチェックアウト）────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_OWNER_PRO=price_...
STRIPE_PRICE_SPONSOR=price_...
